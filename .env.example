# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — Routine Boss
# Copier ce fichier en .env.local et renseigner les valeurs réelles.
# NE JAMAIS commiter .env.local — il est dans .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Identifiants de l'application OAuth (type "Application de bureau") issus de
# Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Refresh token longue durée généré par `npm run calendar` (token.json).
# Nécessite le scope https://www.googleapis.com/auth/calendar (lecture + écriture).
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
